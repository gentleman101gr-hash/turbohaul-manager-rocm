# smoke profile: turbohaul multislot (FE serves + inference executes)
SMOKE_BASE_URL="http://127.0.0.1:11401"
SMOKE_CONTAINER="turbohaul"
SMOKE_HEALTH_PATH="/status"
SMOKE_HTTP_TIMEOUT=10
SMOKE_CHAT_TIMEOUT=300
smoke_probe() {
  assert_http_200 "/status" || return 1
  assert_http_200 "/ui/" || return 1
  assert_chat_completion "qwopus3.6-27b-gpu0" "Reply with exactly one word: PONG" || return 1
  return 0
}
smoke_postcheck() {
  assert_no_log_pattern "Traceback|CRITICAL|unhandled exception" || return 1
  return 0
}
